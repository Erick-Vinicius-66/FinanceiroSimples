@model IEnumerable<FinanceiroSimples.Models.Lançamento>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="bi bi-graph-up-arrow text-primary"></i> Dashboard Financeiro
        </h2>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle"></i> Novo Lançamento
        </a>
    </div>

    <div class="row mb-4 g-3">
        <div class="col-md-4">
            <div class="card text-white bg-success border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="card-title opacity-75">
                        <i class="bi bi-arrow-up-circle"></i> Total De Receitas
                    </h6>
                    <h3 class="fw-bold">R$ @ViewBag.totalReceitas</h3>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-danger border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="card-title opacity-75">
                        <i class="bi bi-arrow-down-circle"></i> Total De Despesas
                    </h6>
                    <h3 class="fw-bold">R$ @ViewBag.TotalDespesas</h3>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-primary border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="card-title opacity-75">
                        <i class="bi bi-cash-stack"></i> Saldo Atual
                    </h6>
                    <h3 class="fw-bold">R$ @ViewBag.Saldo</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 text-secondary"><i class="bi bi-list-ul"></i> Últimos Lançamentos</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Descrição</th>
                            <th>Valor</th>
                            <th>Tipo</th>
                            <th>Categoria</th>
                            <th>Data</th>
                            <th class="text-center pe-4">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold">@item.Descricao</td>
                                <td>R$ @item.Valor</td>
                                <td>
                                    @if (item.Tipo == "Receita")
                                    {
                                        <span class="badge rounded-pill bg-success-subtle text-success border border-success">
                                            <i class="bi bi-arrow-up"></i> Receita
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger">
                                            <i class="bi bi-arrow-down"></i> Despesa
                                        </span>
                                    }
                                </td>
                                <td><span class="text-muted">@item.Categoria</span></td>
                                <td>@item.Data.ToShortDateString()</td>
                                <td class="text-center pe-4">
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-danger"
                                           onclick="return confirm('Deseja realmente excluir?')">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-info-circle fs-2"></i>
                    <p class="mt-2">Nenhum lançamento cadastrado até o momento.</p>
                </div>
            }
        </div>
    </div>
</div>